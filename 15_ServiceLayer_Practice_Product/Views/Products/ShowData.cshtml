@model List<Product>


<div class="container">
    <div class="card shadow-lg mx-auto col-md-6 p-4 myCard">
        <h2 class="text-danger text-center m-2">Product List</h2>
        <form asp-action="ShowData" method="get">
            <div class="mt-3">
                <div class="d-flex gap-3">
                    <input type="text"
                           class="form-control mb-3"
                           placeholder="Search Product..."
                           name="searchText" />
                    <button type="submit"
                            class="btn btn-primary mb-3">
                        Search
                    </button>
                </div>
            </div>

        </form>

        <table class="table table-bordered table-striped table-hover mt-2">
            <thead class="table-warning">
                <tr class="text-center">
                    <th>Id</th>
                    <th>Product Name</th>
                    <th>Price</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="text-center">
                        <td class="align-content-center">@item.Id</td>
                        <td class="align-content-center">@item.Name</td>
                        <td class="text-end align-content-center">₹ @item.Price.ToString("N2")</td>
                        <td>
                            <a asp-action="UpdateData" asp-route-id="@item.Id" class="btn btn-warning">Update</a>
                            <a asp-action="DeleteData" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>